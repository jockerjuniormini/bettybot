# --- CONFIGURACIÓN DE TELEGRAM ---
TELEGRAM_BOT_TOKEN=tu_token_aqui
ALLOWED_USERS=12345678,87654321

# --- CONFIGURACIÓN DE IA (Brains) ---
# Opciones para DEFAULT_BRAIN: ollama, groq, openrouter
DEFAULT_BRAIN=ollama

# Local (Ollama)
OLLAMA_HOST=http://127.0.0.1:11434
LOCAL_MODEL=llama3.1:70b

# Cloud Fallback (Groq)
GROQ_API_KEY=tu_groq_key_aqui
GROQ_MODEL=llama-3.3-70b-versatile

# Cloud (OpenRouter)
OPENROUTER_API_KEY=tu_key_aqui
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct

# --- CONFIGURACION DE VOZ (ElevenLabs) ---
ELEVENLABS_API_KEY=tu_elevenlabs_key_aqui
ELEVENLABS_VOICE_ID=tu_voice_id_aqui

# --- CONFIGURACION DE MEMORIA (Base de Datos) ---
# local_db o cloud_db
DB_TYPE=local_db
GOOGLE_CREDENTIALS_JSON=tu_json_por_si_usas_firestore_aqui

# --- CONFIGURACIÓN DEL SISTEMA ---
PORT=8080
MAC_STUDIO_MODE=true
